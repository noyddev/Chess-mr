generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TournamentStatus {
  UPCOMING
  ACTIVE
  FINISHED
}

model Tournament {
  id          String   @id @default(cuid())
  externalId  String   @unique
  name        String
  location    String
  startDate   DateTime
  endDate     DateTime
  status      TournamentStatus @default(UPCOMING)
  federation  String   @default("Mauritania")
  playerCount Int      @default(0)
  
  players     TournamentPlayer[]
  rounds      Round[]
  
  lastSynced  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([status])
  @@index([startDate])
  @@index([externalId])
}

model TournamentPlayer {
  id            String    @id @default(cuid())
  tournamentId  String
  playerId      String
  seed          Int?
  points        Float     @default(0)
  rank          Int?
  tiebreak1     Float?
  tiebreak2     Float?
  tiebreak3     Float?
  
  tournament    Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player        Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)
  
  @@unique([tournamentId, playerId])
  @@index([tournamentId])
  @@index([playerId])
}

model Player {
  id              String    @id @default(cuid())
  lichessUsername String?   @unique
  fideId          String?   @unique
  name            String
  federation      String    @default("Mauritania")
  
  lichessRapid     Int?
  lichessBlitz     Int?
  lichessClassical Int?
  lichessTitle     String?
  lichessLastSeen  DateTime?
  
  fideRating     Int?
  fideTitle      String?
  
  tournaments    TournamentPlayer[]
  whitePairings  Pairing[] @relation("WhitePlayer")
  blackPairings  Pairing[] @relation("BlackPlayer")
  
  lichessSyncedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([name])
  @@index([lichessUsername])
  @@index([fideId])
}

model Round {
  id           String    @id @default(cuid())
  tournamentId String
  number       Int
  name         String?
  startTime    DateTime?
  
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  pairings     Pairing[]
  
  @@unique([tournamentId, number])
  @@index([tournamentId])
}

model Pairing {
  id            String   @id @default(cuid())
  roundId       String
  board         Int?
  whitePlayerId String?
  blackPlayerId String?
  result        String?
  
  whitePlayer   Player? @relation("WhitePlayer", fields: [whitePlayerId], references: [id], onDelete: SetNull)
  blackPlayer   Player? @relation("BlackPlayer", fields: [blackPlayerId], references: [id], onDelete: SetNull)
  round         Round   @relation(fields: [roundId], references: [id], onDelete: Cascade)
  
  @@index([roundId])
  @@index([whitePlayerId])
  @@index([blackPlayerId])
}

model SyncLog {
  id          String    @id @default(cuid())
  source      String
  status      String
  itemsSynced Int       @default(0)
  skipped     Int       @default(0)
  error       String?
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  
  @@index([source])
  @@index([startedAt])
}
