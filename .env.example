# Database
DATABASE_URL="postgresql://user:password@localhost:5432/chess_mr"

# Optional: Lichess API token for higher rate limits
# LICHESS_TOKEN="your-lichess-token"

# Optional: Cloudflare R2 for image storage
# R2_ACCOUNT_ID="your-r2-account-id"
# R2_ACCESS_KEY_ID="your-access-key"
# R2_SECRET_ACCESS_KEY="your-secret-key"
# R2_BUCKET_NAME="chess-mr-assets"
