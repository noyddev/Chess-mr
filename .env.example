# Chess.MR Environment Configuration
# Copy this file to .env.local for local development

# ============================================
# REQUIRED - Must be set in Vercel Dashboard
# ============================================

# Database - Neon PostgreSQL (Serverless)
# For Vercel, use pooled connection:
# postgresql://user:pass@host/db?sslmode=require
# Do NOT use channel_binding=require with Vercel
DATABASE_URL="postgresql://user:password@host/neondb?sslmode=require"

# Lichess API token for higher rate limits (optional)
LICHESS_TOKEN=""

# ============================================
# OPTIONAL - For Vercel Cron Jobs
# ============================================

# Sync Configuration
SYNC_INTERVAL_ACTIVE=5      # minutes
SYNC_INTERVAL_FINISHED=1440 # minutes (24 hours)
SYNC_BATCH_SIZE=30

# Feature Flags
ENABLE_ADMIN_ENDPOINTS=true

# ============================================
# VERCEL DEPLOYMENT NOTES
# ============================================
# 1. Set DATABASE_URL in Vercel Dashboard → Settings → Environment Variables
# 2. Set LICHESS_TOKEN in Vercel Dashboard (optional)
# 3. Prisma client will be generated during build via vercel.json
