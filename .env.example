# Chess.MR Environment Configuration
# Copy this file to .env.local for local development

# ============================================
# REQUIRED - Must be set in Railway Dashboard
# ============================================

# Database - PostgreSQL connection string
# Get this from your Railway PostgreSQL plugin
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# CRON_SECRET - REQUIRED for Railway Cron Jobs
# Generate a secure random string: openssl rand -hex 32
# Set this in Railway Dashboard → Variables
CRON_SECRET="your-secure-random-secret-here"

# ============================================
# OPTIONAL
# ============================================

# Lichess API token for higher rate limits (optional)
LICHESS_TOKEN=""

# ============================================
# RAILWAY DEPLOYMENT NOTES
# ============================================
# 1. Set DATABASE_URL in Railway Dashboard → Variables
# 2. Set CRON_SECRET in Railway Dashboard → Variables (REQUIRED)
# 3. Railway Cron is configured in railway.json - it will call /api/sync/cron
#    with the Authorization header using the CRON_SECRET
# 4. Make sure the cron service is deployed as part of your Railway project
